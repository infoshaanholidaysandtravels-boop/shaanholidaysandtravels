<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shaan Holidays & Travels</title>

<style>
body{margin:0;font-family:Arial,Helvetica,sans-serif;background:#f4f4f4}
header{background:#0b4da2;color:#fff;padding:16px;text-align:center;font-size:28px;font-weight:bold}
nav{background:#111;padding:12px;text-align:center}
nav a{color:#fff;margin:0 15px;text-decoration:none;font-size:18px}
nav a:hover{color:#ffd000}

.slider{position:relative;width:100%;height:420px;overflow:hidden}
.slide{display:none;width:100%;height:420px;object-fit:cover}
.slide-title{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:white;font-size:42px;font-weight:bold;background:rgba(0,0,0,0.4);padding:15px 30px;border-radius:6px}

.search-box{background:#fff;max-width:900px;margin:40px auto;padding:25px;border-radius:8px;box-shadow:0 0 15px rgba(0,0,0,.15);text-align:center}
.search-box input,.search-box select{padding:10px;margin:8px;width:180px}
.search-box button{padding:12px 20px;background:#0b4da2;color:#fff;border:none;font-size:16px;cursor:pointer}

.results{max-width:900px;margin:20px auto;background:white;padding:20px;border-radius:6px;box-shadow:0 0 10px rgba(0,0,0,.1);display:none}
.flight-card{border-bottom:1px solid #ddd;padding:12px}
.flight-card button{background:#0b4da2;color:white;border:none;padding:6px 10px;margin-left:10px;cursor:pointer}

.payment{background:#fff;padding:30px;margin:40px auto;max-width:600px;border-radius:6px;box-shadow:0 0 10px rgba(0,0,0,.1);display:none;text-align:center}
.payment input{padding:10px;margin:8px;width:80%}
.payment button{padding:12px 20px;background:#0b4da2;color:#fff;border:none}

.ticket{background:#fff;padding:25px;margin:30px auto;max-width:600px;border-radius:6px;box-shadow:0 0 10px rgba(0,0,0,.15);display:none}

.services{padding:40px;text-align:center}
.service-box{background:#fff;width:260px;display:inline-block;padding:25px;margin:15px;border-radius:6px;box-shadow:0 0 10px rgba(0,0,0,.1)}

.package-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:20px}
.package-card{width:260px;background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 0 10px rgba(0,0,0,.15)}
.package-card img{width:100%;height:160px;object-fit:cover}
.package-card h3{margin:10px}
.package-card p{margin:10px;font-size:14px}

.review{background:#fff;padding:20px;width:260px;box-shadow:0 0 10px rgba(0,0,0,.1);border-radius:6px}
.review-slider{max-width:700px;margin:auto;position:relative}
.g-review{display:none;background:white;padding:25px;border-radius:6px;box-shadow:0 0 10px rgba(0,0,0,.1);font-size:16px}

.agent-login{background:#fff;padding:25px;margin:40px auto;max-width:500px;border-radius:6px;box-shadow:0 0 10px rgba(0,0,0,.1);text-align:center}
.agent-login input{padding:10px;margin:8px;width:80%}
.agent-login button{padding:10px 18px;background:#0b4da2;color:white;border:none}

.whatsapp{position:fixed;bottom:20px;right:20px;background:#25D366;color:#fff;padding:15px 18px;border-radius:50px;text-decoration:none;font-weight:bold}
footer{background:#111;color:#fff;text-align:center;padding:20px;margin-top:30px}
</style>
</head>
<body>

<header>Shaan Holidays & Travels</header>

<nav>
<a href="#">Home</a>
<a href="#">Flights</a>
<a href="#">Visa</a>
<a href="#">Packages</a>
<a href="#" onclick="showContact()">Contact</a>
</nav>

<div class="slider">
<img class="slide" src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?auto=format&fit=crop&w=1600&q=60">
<img class="slide" src="https://images.unsplash.com/photo-1502920917128-1aa500764b6e?auto=format&fit=crop&w=1600&q=60">
<img class="slide" src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=60">
<img class="slide" src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=1600&q=60">
<div class="slide-title">Shaan Holidays & Travels</div>
</div>

<div class="search-box">
<h2>Search Flights</h2>
<input id="from" type="text" placeholder="From City">
<input id="to" type="text" placeholder="To City">
<input type="date">
<select>
<option>1 Passenger</option>
<option>2 Passenger</option>
<option>3 Passenger</option>
</select>
<br><br>
<button onclick="searchFlights()">Search Flight</button>
