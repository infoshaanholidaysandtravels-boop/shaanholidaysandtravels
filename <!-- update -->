<div id="results" class="results">
<h3>Available Flights</h3>
<div class="flight-card">Delhi → Dubai | ₹24,500 <button onclick="bookFlight('Delhi','Dubai','24500')">Book</button></div>
<div class="flight-card">Delhi → London | ₹52,000 <button onclick="bookFlight('Delhi','London','52000')">Book</button></div>
<div class="flight-card">Delhi → Toronto | ₹75,000 <button onclick="bookFlight('Delhi','Toronto','75000')">Book</button></div>
</div>

<div id="payment" class="payment">
<h2>Booking Form</h2>
<input id="pname" type="text" placeholder="Passenger Name">
<input id="pphone" type="text" placeholder="Phone Number">
<input id="pemail" type="text" placeholder="Email">
<br>
<button onclick="confirmBooking()">Confirm Booking</button>
</div>

<div id="ticket" class="ticket">
<h2>Your Ticket (Demo)</h2>
<p id="ticketInfo"></p>
<button onclick="downloadTicket()">Download Ticket (PDF)</button>
</div>

<section class="services">
<h2>Our Services</h2>
<div class="service-box">
<h3>International Flights</h3>
<p>Canada, UK, USA, Dubai, Europe routes available.</p>
</div>
<div class="service-box">
<h3>Visa Services</h3>
<p>Tourist visa assistance for major countries.</p>
</div>
<div class="service-box">
<h3>Holiday Packages</h3>
<p>Dubai, Thailand, Singapore tour packages.</p>
</div>
</section>

<section style="padding:40px;text-align:center;background:#fff">
<h2>Our Popular Packages</h2>
<div class="package-grid">
<div class="package-card">
<img src="https://images.unsplash.com/photo-1504215680853-026ed2a45def?auto=format&fit=crop&w=800&q=60">
<h3>Dubai Package</h3>
<p>5 Days / 4 Nights Dubai Holiday</p>
</div>
<div class="package-card">
<img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=800&q=60">
<h3>Thailand Package</h3>
<p>Bangkok + Phuket Tour</p>
</div>
<div class="package-card">
<img src="https://images.unsplash.com/photo-1526772662000-3f88f10405ff?auto=format&fit=crop&w=800&q=60">
<h3>Singapore Package</h3>
<p>4 Nights Singapore Tour</p>
</div>
</div>
</section>

<section style="padding:40px;text-align:center;background:#f9f9f9">
<h2>Google Reviews</h2>
<div class="review-slider">
<div class="g-review">⭐️⭐️⭐️⭐️⭐️<br>"Very good service and cheap flight tickets. Highly recommended."<br><b>- Google Customer</b></div>
<div class="g-review">⭐️⭐️⭐️⭐️⭐️<br>"Best travel agent in Samana. Fast visa support."<br><b>- Google Review</b></div>
<div class="g-review">⭐️⭐️⭐️⭐️⭐️<br>"Booked Dubai tickets. Very smooth process."<br><b>- Happy Client</b></div>
</div>
</section>

<section class="agent-login">
<h2>Agent Login (Demo)</h2>
<input type="text" placeholder="Agent ID">
<input type="password" placeholder="Password">
<br>
<button onclick="alert('Agent panel demo only')">Login</button>
</section>

<section style="padding:40px;text-align:center;background:#fff">
<h2>Our Office Location</h2>
<iframe src="https://maps.google.com/maps?q=Samana%20Patiala%20Punjab&t=&z=13&ie=UTF8&iwloc=&output=embed" width="90%" height="300" style="border:0"></iframe>
</section>

